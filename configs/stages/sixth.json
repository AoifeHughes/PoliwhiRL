        {"type": "location", "positions": [[9, 1, 6, 50]], "hard": true},
        {"type": "location", "positions": [[8, 4, 6, 50], [9, 4, 6, 50]], "hard": true},
        {"type": "location", "positions": [[8, 5, 6, 50], [9, 5, 6, 50]], "hard": true},
        {"type": "location", "positions": [[13, 6, 4, 50]], "hard": true},
        {"type": "location", "positions": [[6, 4, 4, 50]], "hard": true},
        {"type": "location", "positions": [[59, 8, 3, 50], [59, 9, 3, 50]], "hard": false},
        {"type": "location", "positions": [[31, 13, 3, 50]], "hard": false},
        {"type": "pokedex", "kind": "owned", "threshold": 1},
        {"type": "pokedex", "kind": "seen", "threshold": 4}
    ],
    "action_replay_paths": [
        "./emu_files/states/zero.steps",
        "./Training Outputs/fifth_steps/Checkpoints/best/actions.steps"
    ]
